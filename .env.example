# Supabase — get these from your project's API settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Sheets API
# Sheet must have columns A–M in order:
#   A: Route Name, B: Antioquia Region, C: Distance from Medellín,
#   D: Difficulty Level, E: Difficulty (1-5), F: Distance / Duration,
#   G: Max Altitude & Elevation Gain, H: Terrain & Technical Info,
#   I: Category, J: Description, K: YouTube Search Link,
#   L: Photo Search Link, M: Photo URL
VITE_SHEET_ID=your-sheet-id
VITE_SHEETS_API_KEY=your-sheets-api-key

# Admin sync protection — pick any secret string
VITE_ADMIN_TOKEN=your-admin-token

# Supabase Storage — base URL for the trail-photos bucket
VITE_STORAGE_URL=https://your-project.supabase.co/storage/v1/object/public/trail-photos
